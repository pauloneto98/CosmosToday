# ======================================
# CosmosDaily — .gitignore Seguro
# ======================================

# --- Dependências ---
node_modules/
.pnp
.pnp.js

# --- Build / Next.js ---
.next/
out/
build/

# --- Cobertura de Testes ---
coverage/

# ======================================
# 🔐 ARQUIVOS SENSÍVEIS — NUNCA EXPOR
# ======================================

# Variáveis de ambiente (chaves de API, tokens secretos)
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# Chaves SSH e certificados TLS/SSL privados
*.pem
*.key
*.crt
*.p12
*.pfx
*.cert
cosmosdaily-key.pem

# Arquivos compactados de deploy (podem conter código e secrets)
*.tar.gz
*.zip
*.gz
*.rar

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Logs de Debug ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# --- Misc Sistema Operacional ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDEs e Editores ---
.idea/
.vscode/
*.swp
*.swo
*.suo

# --- Vercel / Deploy ---
.vercel

# --- Arquivos internos de planejamento (não relevantes ao código) ---
implementation_plan.md
implementation_plan2
task.md
task2
walkthrough.md
prompt-nasa-saas*.md